install.packages("dplyr")
combined_data <- combined_data %>%
mutate(
TotalClaimAmount = coalesce(TotalClaimAmount, 0)
)
library(dplyr)
# Sum claim amounts for policies with mulitpile claims
sev_aggregated <- freMTPL2sev %>%
group_by(IDpol) %>%
summarize(
TotalClaimAmount = sum(ClaimAmount),
.groups = "drop"
)
library(dplyr)
# Sum claim amounts for policies with multiple claims
sev_aggregated <- freMTPL2sev %>%
group_by(IDpol) %>%
summarize(
TotalClaimAmount = sum(ClaimAmount),
.groups = "drop"
)
library(dplyr)
setwd("C:/Users/tyler/Desktop/Projects/FrenchMotorTPLC_PP_RM_Model")
freMTPL2freq <- read.csv("freMTPL2freq.csv")
freMTPL2sev  <- read.csv("freMTPL2sev.csv")
# Sum claim amounts for policies with multiple claims
sev_aggregated <- freMTPL2sev %>%
group_by(IDpol) %>%
summarize(
TotalClaimAmount = sum(ClaimAmount),
.groups = "drop"
)
# Merge features with aggregated claims amounts
combined_data <- freMTPL2freq %>%
left_join(sev_aggregated, by = "IDpol")
combined_data <- combined_data %>%
mutate(
TotalClaimAmount = coalesce(TotalClaimAmount, 0)
)
